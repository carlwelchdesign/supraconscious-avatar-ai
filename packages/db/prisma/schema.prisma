// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// User model - stores user profile and preferences
model User {
  id                   String   @id @default(cuid())
  email                String   @unique
  passwordHash         String   @default("")
  name                 String?
  role                 String   @default("user") // user, admin, super_admin
  emailVerified        Boolean  @default(false)
  avatarTone           String   @default("balanced") // gentle, balanced, direct
  intensityLevel       Int      @default(3) // 1-5 scale
  currentLevel         Int      @default(1) // 1-5: Awareness to Conscious Choice
  avatarStage          Int      @default(1) // 1-5: Echo to Inner Author
  safetyModeEnabled    Boolean  @default(true)
  patternMemoryEnabled Boolean  @default(false)
  onboardingComplete   Boolean  @default(false)
  topicsToAvoid        Json? // Array of topics to handle gently
  voiceEnabled         Boolean  @default(false)
  voiceAutoPlay        Boolean  @default(false)
  voiceInputDefault    String   @default("text") // text, voice, ask
  voiceGender          String   @default("female") // female, male
  voiceStyle           String   @default("warm") // warm, neutral, deep, soft
  voiceSpeed           Float    @default(1.0) // 0.75, 1.0, 1.25
  preferredLanguage    String   @default("en") // en, es, el, fr, de
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // Relations
  journalEntries   JournalEntry[]
  entryAnalyses    EntryAnalysis[]
  avatarResponses  AvatarResponse[]
  generatedPrompts GeneratedPrompt[]
  patternMemories  PatternMemory[]
  patternMemoryFeedback PatternMemoryFeedback[]
  safetyEvents     SafetyEvent[]
  subscriptions    Subscription[]
  sessions         Session[]
  oauthAccounts    OAuthAccount[]
  webAuthnCredentials WebAuthnCredential[]
  pendingAuthChallenges PendingAuthChallenge[]
  recoveryCodes    RecoveryCode[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens PasswordResetToken[]
  voiceUsageBuckets VoiceUsageBucket[]
  authRateLimitBuckets AuthRateLimitBucket[]
  auditLogs        AuditLog[]
  promptTemplates  PromptTemplate[]
  councilSessions  CouncilSession[]
  embodimentGateResponses EmbodimentGateResponse[]
  sourceDocuments  SourceDocument[]
  sourceImportBatches SourceImportBatch[]
  reasoningGraphRuns ReasoningGraphRun[]
  reasoningOntologyConceptsCreated ReasoningOntologyConcept[] @relation("ReasoningOntologyConceptCreatedBy")
  reasoningOntologyRelationshipsCreated ReasoningOntologyRelationship[] @relation("ReasoningOntologyRelationshipCreatedBy")
  reasoningOntologyClustersCreated ReasoningOntologyCluster[] @relation("ReasoningOntologyClusterCreatedBy")
  reasoningOntologyOutcomesCreated ReasoningOntologyOutcome[] @relation("ReasoningOntologyOutcomeCreatedBy")
  generationTraces GenerationTrace[]
  pilotCohortsCreated PilotCohort[] @relation("PilotCohortCreatedBy")
  pilotEnrollments PilotEnrollment[]
  pilotEvents PilotEvent[]
  consentEvents ConsentEvent[]
  qualityReviews QualityReview[]
  councilSessionFeedback CouncilSessionFeedback[]
  founderCalibrationParticipants FounderCalibrationParticipant[] @relation("FounderCalibrationParticipantUser")
  founderCalibrationParticipantsAdded FounderCalibrationParticipant[] @relation("FounderCalibrationParticipantAddedBy")
  reviewedSafetyEvents SafetyEvent[] @relation("SafetyEventReviewer")
}

// Session - first-party login session stored as a hashed token
model Session {
  id           String   @id @default(cuid())
  userId       String
  tokenHash    String   @unique
  scope        String   @default("web") // web, admin
  authMethod   String   @default("password") // password, google, apple, recovery
  mfaVerifiedAt DateTime?
  mfaMethod    String?  // passkey, recovery_code
  expiresAt    DateTime
  lastSeenAt   DateTime @default(now())
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([scope])
  @@index([expiresAt])
}

// OAuth account link - verified third-party identity bound to a user
model OAuthAccount {
  id                String   @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  email             String
  emailVerified     Boolean  @default(false)
  profile           Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@index([provider, email])
}

// WebAuthn/passkey credential - phishing-resistant authenticator registration
model WebAuthnCredential {
  id                 String    @id @default(cuid())
  userId             String
  credentialId       String    @unique
  publicKey          Bytes
  counter            BigInt    @default(0)
  transports         String[]
  deviceLabel        String
  backedUp           Boolean   @default(false)
  credentialDeviceType String?
  lastUsedAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([lastUsedAt])
}

// Pending auth challenge - short-lived login, MFA, OAuth, and WebAuthn state
model PendingAuthChallenge {
  id         String   @id @default(cuid())
  userId     String?
  tokenHash  String   @unique
  type       String   // oauth_state, mfa, webauthn_registration, webauthn_authentication
  scope      String   @default("web")
  authMethod String?
  challenge  String
  redirectTo String   @default("/dashboard")
  metadata   Json?
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([expiresAt])
  @@index([usedAt])
}

// Recovery code - one-time backup for accounts that enable passkey MFA
model RecoveryCode {
  id        String    @id @default(cuid())
  userId    String
  codeHash  String    @unique
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([usedAt])
}

// Auth rate limit bucket - shared throttling across app instances
model AuthRateLimitBucket {
  id          String   @id @default(cuid())
  userId      String?
  scope       String
  bucketKey   String
  windowStart DateTime
  count       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([scope, bucketKey, windowStart])
  @@index([scope, windowStart])
  @@index([userId])
}

// Voice usage bucket - shared hourly metering across app instances
model VoiceUsageBucket {
  id          String   @id @default(cuid())
  userId      String
  scope       String   // voice_transcribe, voice_speak
  windowStart DateTime
  count       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, scope, windowStart])
  @@index([scope, windowStart])
  @@index([userId])
}

// Email verification token - one-time token stored as a hash only
model EmailVerificationToken {
  id          String    @id @default(cuid())
  userId      String
  tokenHash   String    @unique
  sentToEmail String
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([usedAt])
}

// Password reset token - one-time token stored as a hash only
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([usedAt])
}

// Audit log - immutable record of sensitive admin actions
model AuditLog {
  id         String   @id @default(cuid())
  actorId   String?
  action     String
  targetType String?
  targetId   String?
  reason     String?  @db.Text
  metadata   Json?
  ipAddress  String?
  userAgent  String?  @db.Text
  createdAt  DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
}

// Prompt template - admin-managed prompt/system text configuration
model PromptTemplate {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?  @db.Text
  content     String   @db.Text
  version     Int      @default(1)
  active      Boolean  @default(true)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User? @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([active])
  @@index([createdById])
}

// Founder calibration participant - explicit Carl/Maria setup for real calibration sessions
model FounderCalibrationParticipant {
  id              String   @id @default(cuid())
  email           String   @unique
  userId          String?
  participantRole String   @default("other_founder") // carl, maria, reviewer, other_founder
  status          String   @default("active") // active, paused
  addedById       String?
  reason          String   @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user    User? @relation("FounderCalibrationParticipantUser", fields: [userId], references: [id], onDelete: SetNull)
  addedBy User? @relation("FounderCalibrationParticipantAddedBy", fields: [addedById], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([userId])
  @@index([participantRole])
  @@index([status])
  @@index([addedById])
}

// Feature flag - admin-managed product gates
model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  description String?  @db.Text
  enabled     Boolean  @default(false)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([enabled])
}

// Guide stage config - editable admin metadata for stage presentation
model AvatarStageConfig {
  id          String   @id @default(cuid())
  stage       Int      @unique
  name        String
  description String?  @db.Text
  active      Boolean  @default(true)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active])
}

// Journal entry - raw user input
model JournalEntry {
  id        String   @id @default(cuid())
  userId    String
  rawText   String   @db.Text
  inputMode String   @default("text") // text, voice
  isDraft   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  analysis         EntryAnalysis?
  avatarResponse   AvatarResponse?
  generatedPrompts GeneratedPrompt[]
  patternMemories  PatternMemory[]
  safetyEvents     SafetyEvent[]
  councilSession   CouncilSession?
  embodimentGateResponses EmbodimentGateResponse[]
  pilotEvents      PilotEvent[]

  @@index([userId])
  @@index([createdAt])
}

// Entry analysis - structured AI analysis of journal entry
model EntryAnalysis {
  id             String @id @default(cuid())
  journalEntryId String @unique
  userId         String

  // Analysis results as JSON
  emotionalSignals     Json
  languageMarkers      Json
  behavioralPatterns   Json
  contradictionSignals Json?
  avoidanceSignals     Json?
  intensityScore       Float  @default(0)
  suggestedLevel       Int    @default(1)
  safetyFlags          Json
  summary              String @db.Text

  createdAt DateTime @default(now())

  // Relations
  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

// Avatar response - legacy model name for the reflective guide response
model AvatarResponse {
  id             String @id @default(cuid())
  journalEntryId String @unique
  userId         String

  // Response fields
  openingLine      String? @db.Text
  mirror           String? @db.Text
  patternName      String?
  contradiction    String? @db.Text
  socraticQuestion String? @db.Text
  integrationStep  String? @db.Text
  closingLine      String? @db.Text

  createdAt DateTime @default(now())

  // Relations
  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

// Generated prompt - personalized symbolic journaling prompt
model GeneratedPrompt {
  id             String  @id @default(cuid())
  userId         String
  journalEntryId String?

  // Prompt structure
  level         Int // 1-5
  title         String
  context       String  @db.Text
  materials     String? @db.Text
  execution     String  @db.Text
  integration   String  @db.Text
  targetPattern String?

  userResponse String?   @db.Text
  completedAt  DateTime?

  createdAt DateTime @default(now())

  // Relations
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
}

// Pattern memory - tracked patterns across sessions
model PatternMemory {
  id             String  @id @default(cuid())
  userId         String
  journalEntryId String?

  patternType   String // over-responsibility, people-pleasing, etc.
  patternLabel  String
  evidenceCount Int     @default(1)
  confidence    Float   @default(0)
  examples      Json? // Array of example excerpts
  active        Boolean @default(true)

  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  // Relations
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id], onDelete: SetNull)
  feedback     PatternMemoryFeedback[]

  @@index([userId])
  @@index([patternType])
  @@index([lastSeenAt])
}

// Pattern memory feedback - user/admin correction or suppression signal
model PatternMemoryFeedback {
  id              String   @id @default(cuid())
  userId          String
  patternMemoryId String
  feedbackType    String // helpful, not_accurate, too_intense, suppress, restore
  note            String?  @db.Text
  createdAt       DateTime @default(now())

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  patternMemory PatternMemory @relation(fields: [patternMemoryId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([patternMemoryId])
  @@index([feedbackType])
}

// Council session - one structured Inner Council reflection run
model CouncilSession {
  id             String   @id @default(cuid())
  userId         String
  journalEntryId String   @unique
  status         String   @default("completed") // pending, completed, grounded, failed
  observerSignal Json
  safetySnapshot Json
  sourceMode     String   @default("none") // none, curriculum, rag
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  journalEntry  JournalEntry  @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  messages      CouncilMessage[]
  synthesis     CouncilSynthesis?
  embodimentGateResponses EmbodimentGateResponse[]
  generationTraces GenerationTrace[]
  pilotEvents PilotEvent[]
  qualityReviews QualityReview[]
  feedback CouncilSessionFeedback[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// Council message - bounded role output from an inner archetype
model CouncilMessage {
  id               String   @id @default(cuid())
  councilSessionId String
  role             String // protector, conditioned_self, visionary, truth_self
  displayName      String
  lens             String
  content          String   @db.Text
  evidence         Json?
  confidence       Float    @default(0)
  riskLevel        String   @default("low")
  abstained        Boolean  @default(false)
  abstainReason    String?  @db.Text
  sourceChunkIds   Json?
  createdAt        DateTime @default(now())

  councilSession CouncilSession @relation(fields: [councilSessionId], references: [id], onDelete: Cascade)

  @@index([councilSessionId])
  @@index([role])
}

// Council synthesis - final Head of Council output
model CouncilSynthesis {
  id                 String   @id @default(cuid())
  councilSessionId   String   @unique
  guideName          String   @default("Supraconscious Guide")
  openingLine        String?  @db.Text
  coreTension        String?  @db.Text
  integratorQuestion String   @db.Text
  integrationStep    String   @db.Text
  closingLine        String?  @db.Text
  sourceChunkIds     Json?
  createdAt          DateTime @default(now())

  councilSession CouncilSession @relation(fields: [councilSessionId], references: [id], onDelete: Cascade)
}

// Embodiment Gate response - user-owned micro-shift after integration
model EmbodimentGateResponse {
  id               String   @id @default(cuid())
  userId           String
  journalEntryId   String?
  councilSessionId String?
  text             String   @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  journalEntry   JournalEntry?   @relation(fields: [journalEntryId], references: [id], onDelete: SetNull)
  councilSession CouncilSession? @relation(fields: [councilSessionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([journalEntryId])
  @@index([councilSessionId])
}

// Pilot cohort - bounded pilot group for readiness and operations
model PilotCohort {
  id          String    @id @default(cuid())
  name        String
  status      String    @default("draft") // draft, active, paused, completed
  description String?   @db.Text
  startsAt    DateTime?
  endsAt      DateTime?
  createdById String?
  metadata    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdBy User? @relation("PilotCohortCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  enrollments PilotEnrollment[]

  @@index([status])
  @@index([createdById])
}

// Pilot enrollment - user membership and first-session status for pilot cohorts
model PilotEnrollment {
  id                      String    @id @default(cuid())
  userId                  String
  pilotCohortId           String
  status                  String    @default("invited") // invited, active, completed, removed
  invitedAt               DateTime  @default(now())
  startedAt               DateTime?
  completedFirstSessionAt DateTime?
  removedAt               DateTime?
  metadata                Json?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  pilotCohort PilotCohort @relation(fields: [pilotCohortId], references: [id], onDelete: Cascade)

  @@unique([userId, pilotCohortId])
  @@index([userId])
  @@index([pilotCohortId])
  @@index([status])
}

// Pilot event - privacy-safe lifecycle analytics for pilot readiness
model PilotEvent {
  id               String   @id @default(cuid())
  userId           String?
  journalEntryId   String?
  councilSessionId String?
  eventName        String
  eventVersion     Int      @default(1)
  occurredAt       DateTime @default(now())
  properties       Json?
  inputHash        String?
  sourceMode       String?
  safetySeverity   String?
  featureFlags     Json?
  requestId        String?
  createdAt        DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id], onDelete: SetNull)
  councilSession CouncilSession? @relation(fields: [councilSessionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([journalEntryId])
  @@index([councilSessionId])
  @@index([eventName])
  @@index([occurredAt])
}

// Consent event - immutable acceptance or revocation record for privacy/pilot terms
model ConsentEvent {
  id             String   @id @default(cuid())
  userId         String
  consentType    String // privacy_terms, ai_processing, voice_processing, pattern_memory, pilot_participation, safety_limits
  consentVersion String
  granted        Boolean  @default(true)
  reason         String?  @db.Text
  metadata       Json?
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([consentType])
  @@index([createdAt])
}

// Human quality review - separate from machine validation status
model QualityReview {
  id               String   @id @default(cuid())
  reviewerId       String
  councilSessionId String?
  generationTraceId String?
  targetType       String   @default("CouncilSession")
  label            String // grounded, too_vague, too_intense, unsupported, safety_concern
  severity         String   @default("normal") // normal, pilot_blocker
  reason           String   @db.Text
  metadata         Json?
  reviewedAt       DateTime @default(now())
  createdAt        DateTime @default(now())

  reviewer User @relation(fields: [reviewerId], references: [id], onDelete: Cascade)
  councilSession CouncilSession? @relation(fields: [councilSessionId], references: [id], onDelete: Cascade)
  generationTrace GenerationTrace? @relation(fields: [generationTraceId], references: [id], onDelete: SetNull)

  @@index([reviewerId])
  @@index([councilSessionId])
  @@index([generationTraceId])
  @@index([label])
  @@index([severity])
}

// Council session feedback - direct user feedback on one council session
model CouncilSessionFeedback {
  id               String   @id @default(cuid())
  userId           String
  councilSessionId String
  feedbackType     String // helpful, not_accurate, too_intense, unclear, unsupported_source
  note             String?  @db.Text
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  councilSession CouncilSession @relation(fields: [councilSessionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([councilSessionId])
  @@index([feedbackType])
}

// Source document - canonical source file/version registry
model SourceDocument {
  id           String   @id @default(cuid())
  importedById String?
  importBatchId String?
  title        String
  author       String?
  work         String?
  sourceType   String // manuscript, curriculum, product_doctrine, image, external
  filePath     String?  @db.Text
  checksum     String?  @unique
  language     String   @default("en")
  rightsStatus String   @default("needs_review")
  reviewState  String   @default("imported")
  metadata     Json?
  importedAt   DateTime @default(now())
  updatedAt    DateTime @updatedAt

  importedBy User? @relation(fields: [importedById], references: [id], onDelete: SetNull)
  importBatch SourceImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  sections   SourceSection[]
  chunks     SourceChunk[]
  curriculumDays CurriculumDay[]
  rightsGrants SourceRightsGrant[]
  reasoningGraphEvidence ReasoningGraphEvidence[]
  reasoningOntologyEvidence ReasoningOntologyEvidence[]

  @@index([sourceType])
  @@index([reviewState])
  @@index([rightsStatus])
  @@index([importBatchId])
}

// Source import batch - deterministic corpus import run metadata
model SourceImportBatch {
  id             String   @id @default(cuid())
  initiatedById  String?
  sourceRoot     String   @db.Text
  parserVersion  String
  status         String   @default("completed") // completed, partial, failed
  importedCount  Int      @default(0)
  skippedCount   Int      @default(0)
  failedCount    Int      @default(0)
  errorLog       Json?
  metadata       Json?
  createdAt      DateTime @default(now())
  completedAt    DateTime?

  initiatedBy     User? @relation(fields: [initiatedById], references: [id], onDelete: SetNull)
  sourceDocuments SourceDocument[]

  @@index([status])
  @@index([initiatedById])
  @@index([createdAt])
}

// Source rights grant - reviewable permission and allowed-use record
model SourceRightsGrant {
  id                  String    @id @default(cuid())
  sourceDocumentId    String
  ownerName           String
  grantType           String    @default("provided_by_owner")
  allowedUses         Json
  quoteAllowed        Boolean   @default(false)
  attributionRequired Boolean   @default(false)
  attributionText     String?   @db.Text
  status              String    @default("needs_review") // needs_review, approved, revoked, expired, blocked
  reviewerId          String?
  reviewedAt          DateTime?
  expiresAt           DateTime?
  revokedAt           DateTime?
  reason              String    @db.Text
  metadata            Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  sourceDocument SourceDocument @relation(fields: [sourceDocumentId], references: [id], onDelete: Cascade)

  @@index([sourceDocumentId])
  @@index([status])
  @@index([reviewerId])
}

// Source section - structural unit from books, docs, or product doctrine
model SourceSection {
  id               String   @id @default(cuid())
  sourceDocumentId String
  headingPath      Json?
  sectionType      String   @default("section")
  pageStart        Int?
  pageEnd          Int?
  paragraphStart   Int?
  paragraphEnd     Int?
  canonicalText    String   @db.Text
  reviewState      String   @default("parsed")
  createdAt        DateTime @default(now())

  sourceDocument SourceDocument @relation(fields: [sourceDocumentId], references: [id], onDelete: Cascade)
  chunks         SourceChunk[]

  @@index([sourceDocumentId])
  @@index([sectionType])
  @@index([reviewState])
}

// Source chunk - retrieval unit with provenance
model SourceChunk {
  id               String   @id @default(cuid())
  sourceDocumentId String
  sourceSectionId  String?
  chunkText        String   @db.Text
  quoteSafeExcerpt String?  @db.Text
  tokenCount       Int      @default(0)
  chunkKind        String   @default("semantic")
  sourcePriority   Int      @default(0)
  conceptTags      Json?
  councilRoleTags  Json?
  safetyIntensity  String   @default("normal")
  quotePermission  String   @default("paraphrase_only")
  reviewState      String   @default("parsed")
  embedding        Json?
  createdAt        DateTime @default(now())

  sourceDocument SourceDocument @relation(fields: [sourceDocumentId], references: [id], onDelete: Cascade)
  sourceSection  SourceSection? @relation(fields: [sourceSectionId], references: [id], onDelete: SetNull)
  traces         GenerationTrace[]
  reasoningGraphEvidence ReasoningGraphEvidence[]
  reasoningOntologyEvidence ReasoningOntologyEvidence[]

  @@index([sourceDocumentId])
  @@index([sourceSectionId])
  @@index([reviewState])
  @@index([chunkKind])
}

// Reasoning graph run - admin-generated text-network map over approved source material
model ReasoningGraphRun {
  id                String    @id @default(cuid())
  createdById       String?
  status            String    @default("completed") // completed, failed
  sourceScope       String    @default("approved_sources")
  sourceDocumentIds String[]
  model             String?
  promptVersion     String?
  nodeCount         Int       @default(0)
  edgeCount         Int       @default(0)
  clusterCount      Int       @default(0)
  insightCount      Int       @default(0)
  metadata          Json?
  errorMessage      String?   @db.Text
  createdAt         DateTime  @default(now())
  completedAt       DateTime?

  createdBy User? @relation(fields: [createdById], references: [id], onDelete: SetNull)
  nodes     ReasoningGraphNode[]
  edges     ReasoningGraphEdge[]
  clusters  ReasoningGraphCluster[]
  insights  ReasoningGraphInsight[]
  evidence  ReasoningGraphEvidence[]

  @@index([createdById])
  @@index([status])
  @@index([createdAt])
}

// Reasoning graph cluster - detected community of related concepts
model ReasoningGraphCluster {
  id          String   @id @default(cuid())
  runId       String
  clusterKey  Int
  label       String
  summary     String?  @db.Text
  size        Int      @default(0)
  metrics     Json?
  createdAt   DateTime @default(now())

  run   ReasoningGraphRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  nodes ReasoningGraphNode[]
  ontologyClusters ReasoningOntologyCluster[]

  @@unique([runId, clusterKey])
  @@index([runId])
}

// Reasoning graph node - concept, claim, goal, result, or source-backed idea
model ReasoningGraphNode {
  id              String   @id @default(cuid())
  runId           String
  clusterId       String?
  nodeKey         String
  nodeType        String   @default("concept")
  label           String
  normalizedLabel String
  summary         String?  @db.Text
  degree          Int      @default(0)
  weightedDegree  Float    @default(0)
  betweenness     Float    @default(0)
  bridgeScore     Float    @default(0)
  reviewState     String   @default("unreviewed") // unreviewed, approved, rejected, needs_revision
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  run          ReasoningGraphRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  cluster      ReasoningGraphCluster? @relation(fields: [clusterId], references: [id], onDelete: SetNull)
  outgoingEdges ReasoningGraphEdge[] @relation("ReasoningGraphEdgeFrom")
  incomingEdges ReasoningGraphEdge[] @relation("ReasoningGraphEdgeTo")
  evidence     ReasoningGraphEvidence[]
  ontologyConcepts ReasoningOntologyConcept[]

  @@unique([runId, nodeKey])
  @@index([runId])
  @@index([clusterId])
  @@index([nodeType])
  @@index([reviewState])
}

// Reasoning graph edge - weighted relationship between source-backed ideas
model ReasoningGraphEdge {
  id           String   @id @default(cuid())
  runId        String
  fromNodeId   String
  toNodeId     String
  edgeKey      String
  relationType String   @default("co_occurs")
  weight       Int      @default(1)
  confidence   Float    @default(0)
  rationale    String?  @db.Text
  reviewState  String   @default("unreviewed") // unreviewed, approved, rejected, needs_revision
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  run      ReasoningGraphRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  fromNode ReasoningGraphNode @relation("ReasoningGraphEdgeFrom", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNode   ReasoningGraphNode @relation("ReasoningGraphEdgeTo", fields: [toNodeId], references: [id], onDelete: Cascade)
  evidence ReasoningGraphEvidence[]
  ontologyRelationships ReasoningOntologyRelationship[]

  @@unique([runId, edgeKey])
  @@index([runId])
  @@index([fromNodeId])
  @@index([toNodeId])
  @@index([relationType])
  @@index([reviewState])
}

// Reasoning graph insight - generated or deterministic interpretation of graph structure
model ReasoningGraphInsight {
  id          String   @id @default(cuid())
  runId       String
  insightType String
  title       String
  summary     String   @db.Text
  confidence  Float    @default(0)
  reviewState String   @default("unreviewed") // unreviewed, approved, rejected, needs_revision
  nodeIds     Json?
  edgeIds     Json?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  run      ReasoningGraphRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  evidence ReasoningGraphEvidence[]
  ontologyOutcomes ReasoningOntologyOutcome[]

  @@index([runId])
  @@index([insightType])
  @@index([reviewState])
}

// Reasoning graph evidence - source trace behind nodes, edges, and insights
model ReasoningGraphEvidence {
  id               String   @id @default(cuid())
  runId            String
  nodeId           String?
  edgeId           String?
  insightId        String?
  sourceDocumentId String?
  sourceChunkId    String?
  evidenceKind     String   @default("source_chunk")
  excerpt          String?  @db.Text
  weight           Float    @default(1)
  metadata         Json?
  createdAt        DateTime @default(now())

  run            ReasoningGraphRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  node           ReasoningGraphNode? @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  edge           ReasoningGraphEdge? @relation(fields: [edgeId], references: [id], onDelete: Cascade)
  insight        ReasoningGraphInsight? @relation(fields: [insightId], references: [id], onDelete: Cascade)
  sourceDocument SourceDocument? @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  sourceChunk    SourceChunk? @relation(fields: [sourceChunkId], references: [id], onDelete: SetNull)

  @@index([runId])
  @@index([nodeId])
  @@index([edgeId])
  @@index([insightId])
  @@index([sourceDocumentId])
  @@index([sourceChunkId])
}

// Durable approved ontology concept promoted from generated reasoning graph candidates
model ReasoningOntologyConcept {
  id              String   @id @default(cuid())
  conceptKey      String   @unique
  canonicalLabel  String
  aliases         String[] @default([])
  description     String?  @db.Text
  reviewState     String   @default("approved") // approved, rejected, needs_revision, archived
  pinned          Boolean  @default(false)
  sourceGraphNodeId String?
  metadata        Json?
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  createdBy User? @relation("ReasoningOntologyConceptCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  sourceGraphNode ReasoningGraphNode? @relation(fields: [sourceGraphNodeId], references: [id], onDelete: SetNull)
  outgoingRelationships ReasoningOntologyRelationship[] @relation("ReasoningOntologyRelationshipFrom")
  incomingRelationships ReasoningOntologyRelationship[] @relation("ReasoningOntologyRelationshipTo")
  clusterMemberships ReasoningOntologyClusterConcept[]
  outcomeLinks ReasoningOntologyOutcomeConcept[]
  evidence ReasoningOntologyEvidence[]

  @@index([conceptKey])
  @@index([reviewState])
  @@index([pinned])
  @@index([sourceGraphNodeId])
  @@index([createdById])
}

// Durable typed relationship between approved ontology concepts
model ReasoningOntologyRelationship {
  id              String   @id @default(cuid())
  relationshipKey String  @unique
  fromConceptId   String
  toConceptId     String
  relationType    String  // causal, hierarchical, associative, tension, practice_to_outcome, supports, gap_bridge
  rationale       String? @db.Text
  confidence      Float   @default(0)
  reviewState     String  @default("approved") // approved, rejected, needs_revision, archived
  sourceGraphEdgeId String?
  metadata        Json?
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  createdBy User? @relation("ReasoningOntologyRelationshipCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  fromConcept ReasoningOntologyConcept @relation("ReasoningOntologyRelationshipFrom", fields: [fromConceptId], references: [id], onDelete: Cascade)
  toConcept ReasoningOntologyConcept @relation("ReasoningOntologyRelationshipTo", fields: [toConceptId], references: [id], onDelete: Cascade)
  sourceGraphEdge ReasoningGraphEdge? @relation(fields: [sourceGraphEdgeId], references: [id], onDelete: SetNull)
  evidence ReasoningOntologyEvidence[]

  @@index([fromConceptId])
  @@index([toConceptId])
  @@index([relationType])
  @@index([reviewState])
  @@index([sourceGraphEdgeId])
  @@index([createdById])
}

// Durable curated theme or cluster inside the approved ontology
model ReasoningOntologyCluster {
  id              String   @id @default(cuid())
  clusterKey      String   @unique
  label           String
  summary         String?  @db.Text
  reviewState     String   @default("approved")
  sourceGraphClusterId String?
  metadata        Json?
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  createdBy User? @relation("ReasoningOntologyClusterCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  sourceGraphCluster ReasoningGraphCluster? @relation(fields: [sourceGraphClusterId], references: [id], onDelete: SetNull)
  concepts ReasoningOntologyClusterConcept[]
  evidence ReasoningOntologyEvidence[]

  @@index([reviewState])
  @@index([sourceGraphClusterId])
  @@index([createdById])
}

model ReasoningOntologyClusterConcept {
  id        String @id @default(cuid())
  clusterId String
  conceptId String
  weight    Float  @default(1)
  createdAt DateTime @default(now())

  cluster ReasoningOntologyCluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  concept ReasoningOntologyConcept @relation(fields: [conceptId], references: [id], onDelete: Cascade)

  @@unique([clusterId, conceptId])
  @@index([conceptId])
}

// Durable stakeholder outcome path curated from graph insights
model ReasoningOntologyOutcome {
  id              String   @id @default(cuid())
  outcomeKey      String   @unique
  label           String
  summary         String?  @db.Text
  missingAreas    String[] @default([])
  reviewState     String   @default("approved")
  sourceGraphInsightId String?
  metadata        Json?
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  createdBy User? @relation("ReasoningOntologyOutcomeCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  sourceGraphInsight ReasoningGraphInsight? @relation(fields: [sourceGraphInsightId], references: [id], onDelete: SetNull)
  concepts ReasoningOntologyOutcomeConcept[]
  evidence ReasoningOntologyEvidence[]

  @@index([reviewState])
  @@index([sourceGraphInsightId])
  @@index([createdById])
}

model ReasoningOntologyOutcomeConcept {
  id        String @id @default(cuid())
  outcomeId String
  conceptId String
  role      String @default("supports") // supports, missing, bridge
  weight    Float  @default(1)
  createdAt DateTime @default(now())

  outcome ReasoningOntologyOutcome @relation(fields: [outcomeId], references: [id], onDelete: Cascade)
  concept ReasoningOntologyConcept @relation(fields: [conceptId], references: [id], onDelete: Cascade)

  @@unique([outcomeId, conceptId, role])
  @@index([conceptId])
}

// Source provenance for approved ontology records
model ReasoningOntologyEvidence {
  id             String   @id @default(cuid())
  conceptId      String?
  relationshipId String?
  clusterId      String?
  outcomeId      String?
  sourceDocumentId String?
  sourceChunkId  String?
  evidenceKind   String   @default("source_chunk")
  excerpt        String?  @db.Text
  weight         Float    @default(1)
  metadata       Json?
  createdAt      DateTime @default(now())

  concept ReasoningOntologyConcept? @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  relationship ReasoningOntologyRelationship? @relation(fields: [relationshipId], references: [id], onDelete: Cascade)
  cluster ReasoningOntologyCluster? @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  outcome ReasoningOntologyOutcome? @relation(fields: [outcomeId], references: [id], onDelete: Cascade)
  sourceDocument SourceDocument? @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  sourceChunk SourceChunk? @relation(fields: [sourceChunkId], references: [id], onDelete: SetNull)

  @@index([conceptId])
  @@index([relationshipId])
  @@index([clusterId])
  @@index([outcomeId])
  @@index([sourceDocumentId])
  @@index([sourceChunkId])
}

// Curriculum day - structured monthly quote/frame/question content
model CurriculumDay {
  id               String   @id @default(cuid())
  sourceDocumentId String?
  month            Int
  day              Int
  theme            String
  title            String?
  quote            String?  @db.Text
  frameOfThought   String   @db.Text
  socraticQuestion String   @db.Text
  publishState     String   @default("needs_review")
  metadata         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  sourceDocument SourceDocument? @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)

  @@unique([month, day])
  @@index([publishState])
  @@index([theme])
}

// Generation trace - source and model provenance for AI outputs
model GenerationTrace {
  id               String   @id @default(cuid())
  userId           String?
  councilSessionId String?
  sourceChunkId    String?
  traceType        String // retrieval, council, synthesis, prompt, safety
  model            String?
  promptVersion    String?
  inputHash        String?
  outputJson       Json?
  validationStatus String   @default("unreviewed")
  latencyMs        Int?
  tokenUsage       Json?
  fallbackReason   String?  @db.Text
  createdAt        DateTime @default(now())

  user           User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  councilSession CouncilSession? @relation(fields: [councilSessionId], references: [id], onDelete: SetNull)
  sourceChunk    SourceChunk?    @relation(fields: [sourceChunkId], references: [id], onDelete: SetNull)
  qualityReviews QualityReview[]

  @@index([userId])
  @@index([councilSessionId])
  @@index([traceType])
  @@index([validationStatus])
}

// Safety event - logged safety concerns
model SafetyEvent {
  id             String  @id @default(cuid())
  userId         String
  journalEntryId String?

  severity          String // none, low, medium, high
  flags             Json // Array of detected flags
  recommendedAction String?
  resolved          Boolean @default(false)
  reviewStatus      String  @default("unreviewed") // unreviewed, reviewing, resolved, escalated
  reviewerId        String?
  reviewReason      String? @db.Text
  resolvedAt        DateTime?

  createdAt DateTime @default(now())

  // Relations
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id], onDelete: SetNull)
  reviewer     User?         @relation("SafetyEventReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([severity])
  @@index([reviewStatus])
  @@index([reviewerId])
  @@index([createdAt])
}

// Subscription - Stripe subscription data
model Subscription {
  id     String @id @default(cuid())
  userId String

  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique
  stripePriceId        String?
  plan                 String  @default("free") // free, starter, pro
  status               String  @default("inactive") // active, inactive, past_due, canceled

  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([stripeCustomerId])
}
