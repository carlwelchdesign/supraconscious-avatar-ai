{
  "name": "inner-avatar-ai",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@4.6.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "turbo dev --filter=@inner-avatar/web",
    "dev:admin": "turbo dev --filter=@inner-avatar/admin",
    "dev:founder-calibration": "turbo dev --filter=@inner-avatar/web --filter=@inner-avatar/admin",
    "dev:chatgpt": "turbo dev --filter=@inner-avatar/chatgpt-app",
    "build:web": "turbo build --filter=@inner-avatar/web",
    "build:admin": "turbo build --filter=@inner-avatar/admin",
    "build:chatgpt": "turbo build --filter=@inner-avatar/chatgpt-app",
    "docker:build:web": "docker build -f apps/web/Dockerfile -t inner-avatar-web:latest .",
    "docker:build:admin": "docker build -f apps/admin/Dockerfile -t inner-avatar-admin:latest .",
    "docker:build:chatgpt": "docker build -f apps/chatgpt-app/Dockerfile -t inner-avatar-chatgpt-app:latest .",
    "docker:compose:up": "docker compose up --build",
    "docker:compose:down": "docker compose down",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test:auth": "yarn --cwd packages/auth test",
    "test:ai": "yarn --cwd packages/ai test",
    "test:rag": "yarn --cwd packages/ai test:rag",
    "test:pilot": "yarn --cwd packages/ai test:pilot",
    "smoke:rag": "yarn --cwd packages/ai smoke:rag",
    "test:chatgpt": "yarn --cwd apps/chatgpt-app test",
    "setup:founder-calibration": "yarn --cwd packages/ai setup:founder-calibration",
    "handoff:founder-calibration": "yarn --cwd packages/ai handoff:founder-calibration",
    "packet:founder-calibration": "yarn --cwd packages/ai packet:founder-calibration",
    "smoke:founder-local": "yarn --cwd packages/ai smoke:founder-local",
    "report:founder-calibration": "yarn --cwd packages/ai report:founder-calibration",
    "report:founder-calibration-comparison": "yarn --cwd packages/ai report:founder-calibration-comparison",
    "report:founder-calibration-setup": "yarn --cwd packages/ai report:founder-calibration-setup",
    "check:founder-calibration-launch": "yarn --cwd packages/ai check:founder-calibration-launch",
    "test:founder-calibration": "yarn --cwd packages/ai test:founder-calibration",
    "test:founder-calibration-regression": "yarn --cwd packages/ai test:founder-calibration-regression",
    "verify:founder-calibration-code": "yarn db:generate && yarn test:auth && yarn test:ai && yarn test:rag && yarn test:pilot && yarn smoke:rag && yarn test:founder-calibration && yarn test:founder-calibration-regression && yarn report:founder-calibration-setup && yarn report:founder-calibration && yarn report:founder-calibration-comparison && yarn typecheck && yarn lint && yarn build:web && yarn build:admin && yarn build:chatgpt && yarn test:chatgpt",
    "db:generate": "prisma generate",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "postinstall": "prisma generate",
    "vercel:install": "node .yarn/releases/yarn-4.cjs install --immutable",
    "vercel:build": "node .yarn/releases/yarn-4.cjs --cwd apps/web build && node .yarn/releases/yarn-4.cjs --cwd apps/admin build && node .yarn/releases/yarn-4.cjs --cwd apps/chatgpt-app build"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "prisma": "^7.8.0",
    "turbo": "^2.6.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "typescript": "^5"
  }
}
