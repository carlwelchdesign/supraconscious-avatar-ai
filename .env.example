# Supraconscious environment template

# Database
# Production managed Postgres URLs should use sslmode=verify-full when TLS is required.
# Local Docker/Compose intentionally uses sslmode=disable.
DATABASE_URL="postgres://user:password@localhost:5432/inner_avatar?sslmode=disable"
# Optional local debugging only. Leave false/blank for founder testing so raw query parameters stay out of logs.
PRISMA_QUERY_LOGGING="false"

# Docker Compose local database defaults
POSTGRES_DB="inner_avatar"
POSTGRES_USER="inner_avatar"
POSTGRES_PASSWORD="inner_avatar_dev"
POSTGRES_PORT=5433
COMPOSE_DATABASE_URL="postgresql://inner_avatar:inner_avatar_dev@postgres:5432/inner_avatar?sslmode=disable"

# First-party auth and admin bootstrap
# Matching emails become super_admin during registration/login.
SUPER_ADMIN_EMAILS="admin@example.com"
AUTH_SECRET="replace-with-a-long-random-secret"

# Transactional auth email. Leave blank for local manual/admin-only verification.
RESEND_API_KEY=""
AUTH_EMAIL_FROM="Supraconscious <no-reply@example.com>"

# Optional managed bot challenge for auth forms.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Social login and phishing-resistant MFA
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_IOS_CLIENT_ID=""
GOOGLE_OAUTH_ANDROID_CLIENT_ID=""
APPLE_OAUTH_CLIENT_ID=""
APPLE_IOS_BUNDLE_ID="co.supraconscious.innerCouncilMobile"
APPLE_TEAM_ID=""
APPLE_KEY_ID=""
# Paste the PEM on one line with escaped newlines for Vercel, or as a multiline value locally.
APPLE_PRIVATE_KEY=""
WEBAUTHN_RP_ID=""
WEBAUTHN_EXPECTED_ORIGINS=""
IOS_BUNDLE_ID="co.supraconscious.innerCouncilMobile"
ANDROID_PACKAGE_NAME="co.supraconscious.inner_council_mobile"
ANDROID_SHA256_CERT_FINGERPRINTS=""

# OpenAI
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-5-mini"

# Optional LangSmith observability. Disabled by default and metadata-only when enabled.
LANGSMITH_TRACING="false"
LANGSMITH_API_KEY=""
LANGSMITH_PROJECT="inner-avatar-dev"
LANGSMITH_ENDPOINT=""
LANGSMITH_SAMPLE_RATE="1"
LANGSMITH_METADATA_ONLY="true"
# Optional compatibility aliases for LangSmith SDK conventions.
LANGCHAIN_API_KEY=""
LANGCHAIN_TRACING_V2="false"
LANGCHAIN_PROJECT="inner-avatar-dev"

# App URLs
NEXT_PUBLIC_APP_URL="http://localhost:3000"
INNER_AVATAR_WEB_URL="http://localhost:3000"
NEXT_PUBLIC_ADMIN_URL="http://localhost:3001"
# Daily journal curriculum and "today" labels use this IANA timezone.
APP_TIME_ZONE="America/Los_Angeles"

# Stripe billing
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_STARTER_PRICE_ID="price_..."
STRIPE_PRO_PRICE_ID="price_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ChatGPT/MCP app
CHATGPT_APP_PORT=3002
CHATGPT_APP_API_TOKEN="replace-with-a-long-random-token"

# Docker utility scripts
DOCKER_PREFLIGHT_TIMEOUT_MS=8000

# Flutter/mobile utility scripts
FLUTTER_PREFLIGHT_TIMEOUT_MS=15000

# Founder calibration setup and handoff helpers
FOUNDER_CALIBRATION_EMAILS="carlwelchdesign+supra@gmail.com,meliatsaroucha@gmail.com"
FOUNDER_CALIBRATION_CARL_EMAIL="carlwelchdesign+supra@gmail.com"
FOUNDER_CALIBRATION_MARIA_EMAIL="meliatsaroucha@gmail.com"
FOUNDER_CALIBRATION_REVIEWER_EMAILS=""
FOUNDER_CALIBRATION_SETUP_ACTOR_EMAIL="carlwelchdesign+supra@gmail.com"
FOUNDER_HANDOFF_WEB_URL="http://localhost:3000"
FOUNDER_HANDOFF_ADMIN_URL="http://localhost:3001"

# Internal RAG/pilot utility scripts
OBSIDIAN_VAULT_PATH=""
INTERNAL_RAG_ACTOR_EMAIL=""
INTERNAL_RAG_SMOKE_USER_EMAIL="demo@inner-avatar.ai"
INTERNAL_RAG_SMOKE_SEED_FIXTURES="true"
INTERNAL_RAG_SMOKE_USE_OPENAI="false"
PILOT_COHORT_ID="internal-pilot"
PILOT_COHORT_NAME="Internal Pilot"
PILOT_USER_EMAILS=""
PILOT_EXPANSION_STRICT="false"
