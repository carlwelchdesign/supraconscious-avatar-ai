# Inner Avatar AI environment template

# Database
DATABASE_URL="postgres://user:password@localhost:5432/inner_avatar"

# First-party auth and admin bootstrap
# Matching emails become super_admin during registration/login.
SUPER_ADMIN_EMAILS="admin@example.com"
AUTH_SECRET="replace-with-a-long-random-secret"

# Transactional auth email. Leave blank for local manual/admin-only verification.
RESEND_API_KEY=""
AUTH_EMAIL_FROM="Inner Avatar <no-reply@example.com>"

# OpenAI
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-5-mini"

# App URLs
NEXT_PUBLIC_APP_URL="http://localhost:3000"
INNER_AVATAR_WEB_URL="http://localhost:3000"
NEXT_PUBLIC_ADMIN_URL="http://localhost:3001"

# Stripe billing
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_STARTER_PRICE_ID="price_..."
STRIPE_PRO_PRICE_ID="price_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ChatGPT/MCP app
CHATGPT_APP_PORT=3002

# Founder calibration setup and handoff helpers
FOUNDER_CALIBRATION_EMAILS="carl@example.com,maria@example.com"
FOUNDER_CALIBRATION_CARL_EMAIL="carl@example.com"
FOUNDER_CALIBRATION_MARIA_EMAIL="maria@example.com"
FOUNDER_CALIBRATION_REVIEWER_EMAILS=""
FOUNDER_CALIBRATION_SETUP_ACTOR_EMAIL="admin@example.com"
FOUNDER_HANDOFF_WEB_URL="http://localhost:3000"
FOUNDER_HANDOFF_ADMIN_URL="http://localhost:3001"

# Internal RAG/pilot utility scripts
INTERNAL_RAG_ACTOR_EMAIL="admin@example.com"
INTERNAL_RAG_SMOKE_USER_EMAIL="demo@inner-avatar.ai"
INTERNAL_RAG_SMOKE_USE_OPENAI="false"
PILOT_COHORT_ID="internal-pilot"
PILOT_COHORT_NAME="Internal Pilot"
PILOT_USER_EMAILS=""
PILOT_EXPANSION_STRICT="false"
