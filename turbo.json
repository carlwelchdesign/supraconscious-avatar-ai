{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"]
    },
    "@inner-avatar/ai#build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@inner-avatar/auth#build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@inner-avatar/billing#build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@inner-avatar/db#build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@inner-avatar/types#build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@inner-avatar/ui#build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    }
  }
}
